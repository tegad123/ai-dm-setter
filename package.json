{
  "name": "next-shadcn-dashboard-starter",
  "version": "1.0.0",
  "private": true,
  "author": {
    "name": "Kiran",
    "url": "https://github.com/Kiranism"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && tsx scripts/lint-schema-defaults.ts && tsx scripts/safe-migrate.ts && next build",
    "db:check-drift": "tsx scripts/check-schema-drift.ts",
    "db:lint-schema": "tsx scripts/lint-schema-defaults.ts",
    "db:migrate-safe": "tsx scripts/safe-migrate.ts",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint src --fix && bun format",
    "lint:strict": "eslint --max-warnings=0 src",
    "format": "prettier --write .",
    "format:check": "prettier -c -w .",
    "prepare": "husky",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:auth": "tsx tests/e2e/helpers/auth.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "lint-staged": {
    "**/*.{js,jsx,tsx,ts,css,less,scss,sass}": [
      "prettier --write --no-error-on-unmatched-pattern"
    ]
  },
