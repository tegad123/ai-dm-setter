# ---------------------------------------------------------------------------
# .env.test — Playwright e2e test credentials
# ---------------------------------------------------------------------------
# Copy this file to .env.test (gitignored) and fill in a dedicated test
# Clerk account. Used by tests/e2e/helpers/auth.ts to capture a
# storage-state.json for the test suite.
#
# Suggested setup: create a fresh Clerk user "playwright@yourdomain.com"
# (or use Clerk's "Test Mode" if your project has it enabled), give it
# a workspace with a couple of seeded conversations, and put its
# credentials here.
# ---------------------------------------------------------------------------

CLERK_TEST_EMAIL=
CLERK_TEST_PASSWORD=

# Override the dev server origin if not running on the default port.
# PLAYWRIGHT_BASE_URL=http://localhost:3000
