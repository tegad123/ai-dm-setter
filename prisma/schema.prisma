generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum Role {
  ADMIN
  CLOSER
  SETTER
  READ_ONLY
  // Platform-level operator (Tega). Sees /admin dashboard across ALL
  // tenant accounts, can impersonate, run health checks, manage plans.
  // Set via scripts/promote-tega-super-admin.ts; never assigned via UI.
  SUPER_ADMIN
  // Platform manager. Can view/action all tenant conversations from
  // /admin, but cannot manage billing, delete accounts, or edit platform
  // admin settings.
  MANAGER
}

enum PlanStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum AccountHealthStatus {
  HEALTHY
  WARNING
  CRITICAL
  UNKNOWN
}

enum Platform {
  INSTAGRAM
  FACEBOOK
}

enum LeadStage {
  NEW_LEAD
  ENGAGED
  QUALIFYING
  QUALIFIED
  CALL_PROPOSED
  BOOKED
  SHOWED
  NO_SHOWED
  RESCHEDULED
  CLOSED_WON
  CLOSED_LOST
  UNQUALIFIED
  GHOSTED
  NURTURE
}

