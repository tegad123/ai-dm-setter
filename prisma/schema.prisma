// ─── Multi-Tenant Models ────────────────────────────────

model Account {
  id                 String      @id @default(cuid())
  name               String                          // Business name
  slug               String      @unique             // URL-safe identifier
  logoUrl            String?
  brandName          String?                         // Display name (optional override)
  primaryColor       String?     @default("#2563EB") // Brand color
  onboardingComplete Boolean     @default(false)
  plan               AccountPlan @default(FREE)
  // Per-platform AI Auto-Send toggles. These are the MASTER switch that
  // enables AI auto-reply for an entire platform. Required for any
  // auto-send: the webhook-processor requires BOTH this flag AND the
  // per-conversation `Conversation.aiActive` to be true before sending.
  // With the flag OFF, new lead conversations are created with
  // aiActive=false and no auto-sends occur on that platform — the AI
  // still generates suggestions that surface in the dashboard but
  // nothing ships to the platform. Flipping the flag ON is an explicit
  // "I want AI to handle new Instagram/Facebook leads from now on"
  // opt-in. Legacy single `awayMode` field is retained for the
  // migration window but no longer read at runtime.
  awayMode           Boolean     @default(false)     // DEPRECATED — superseded by awayMode{Instagram,Facebook}
  awayModeEnabledAt  DateTime?                       // DEPRECATED
  awayModeInstagram           Boolean   @default(false)
  awayModeInstagramEnabledAt  DateTime?
  awayModeFacebook            Boolean   @default(false)
  awayModeFacebookEnabledAt   DateTime?
  ghostThresholdDays Int         @default(7)         // Days of silence before auto-ghost

  // ── Closed-Loop Training ──────────────────────────────────
  trainingPhase              TrainingPhase @default(ONBOARDING)
  trainingPhaseStartedAt     DateTime      @default(now())
  trainingPhaseCompletedAt   DateTime?
  trainingTargetOverrideCount Int          @default(20) // Overrides needed to suggest "training complete"
  trainingOverrideCount      Int           @default(0)  // Incremented on each human override during onboarding

  // ── Global AI Response Timing (applies to all scripts) ────
  responseDelayMin           Int           @default(300) // Min response delay in seconds (default 5 min)
  responseDelayMax           Int           @default(600) // Max response delay in seconds (default 10 min)

  // Debounce: wait this many seconds of silence from the lead before
  // generating. Each new lead message resets the timer. maxDebounceWindow
  // is a hard cap measured from the FIRST message in the current batch so
  // the AI doesn't go silent indefinitely on a chatty lead.
  debounceWindowSeconds      Int           @default(45)
  maxDebounceWindowSeconds   Int           @default(120)

  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  // Relations
  users              User[]
  leads              Lead[]
  notifications      Notification[]
  personas           AIPersona[]
  trainingExamples   TrainingExample[]
  trainingUploads    TrainingUpload[]
  trainingConversations TrainingConversation[]
  personaBreakdowns  PersonaBreakdown[]
  integrations       IntegrationCredential[]
  tags               Tag[]
  teamNotes          TeamNote[]
  contentAttributions ContentAttribution[]
  voiceNoteSlots     VoiceNoteSlot[]
  voiceNoteLibrary   VoiceNoteLibraryItem[]
  voiceNoteTimingSettings VoiceNoteTimingSettings?
  scriptSlots        ScriptSlot[]
  scripts            Script[]
  trainingAnalyses   TrainingDataAnalysis[]
  aiSuggestions      AISuggestion[]
  inboundQualifications InboundQualification[]

  @@index([slug])
}

model AIPersona {
  id                       String   @id @default(cuid())
  accountId                String
  personaName              String                    // e.g. "Sales Daniel"
  fullName                 String                    // e.g. "Daniel Elumelu"
  companyName              String?                   // e.g. "DAE Trading Accelerator"
  tone                     String?                   // e.g. "casual, direct, friendly"
  systemPrompt             String   @db.Text         // Main conversation prompt
  qualificationFlow        Json?                     // JSON array of qualification steps
  objectionHandling        Json?                     // JSON object for objection responses
  voiceNoteDecisionPrompt  String?  @db.Text
  qualityScoringPrompt     String?  @db.Text
  freeValueLink            String?                   // Bootcamp/resource URL
  customPhrases            Json?                     // JSON: {"greeting": "yo", "affirmation": "bet"}
  promptConfig             Json?                     // All template variables: {whatYouSell, adminBio, toneDescription, ...}
  rawScript                String?  @db.Text          // Full uploaded sales script (plain text)
  rawScriptFileName        String?                    // Original filename for UI display
  styleAnalysis            String?  @db.Text          // AI-generated style analysis (markdown)
  financialWaterfall       Json?                     // [{label, question, threshold?, passAction}]
  downsellConfig           Json?                     // {productName, price, pitchMessage, link}
  knowledgeAssets          Json?                     // [{key, title, content, deployTrigger}]
  proofPoints              Json?                     // [{name, result, deployContext}]
  noShowProtocol           Json?                     // {firstNoShow, secondNoShow, maxReschedules}
  preCallSequence          Json?                     // [{timing, message}]
  closerName               String?                   // Name of closer on calls (e.g. "Anthony")
  // Day-to-day operator-edited context. activeCampaignsContext is free-
  // form text listing the account's current CTAs, content drops, and
  // promotions; the prompt injects it as an <active_campaigns> block so
  // the AI can recognise warm CTA responses vs cold DMs. The other two
  // fields track who last edited any persona context and when, so the
  // persona editor UI can show "Last updated 2 days ago by X" and give
  // operators an audit trail without a separate history table.
  activeCampaignsContext   String?  @db.Text
  contextUpdatedAt         DateTime?
  contextUpdatedByUserId   String?
  // Capital-verification gate (R24). When set, the AI must verify the
  // lead's capital claim in DM before routing to booking — leads lie on
  // Typeform. If null, verification is skipped (backward compatible).
  // capitalVerificationPrompt is an optional override if the operator
  // wants custom wording; otherwise the default R24 phrasing is used.
  minimumCapitalRequired   Int?
  capitalVerificationPrompt String? @db.Text
  // Scope & Limits (R26). Free-form list of topics the AI should
  // politely decline — career advice, crypto, general investing, etc.
  // Augments the universal R26 "stay in scope" rule with account-specific
  // carveouts so a financial-literacy coach doesn't get false positives
  // on the off-topic regex guard, and a trading coach gets an explicit
  // "do NOT discuss general wealth-building" reinforcement.
  outOfScopeTopics         String?  @db.Text
  // R27: verified third-party facts the AI is allowed to assert. When a
  // lead asks about things the account owner hasn't personally disclosed
  // to the AI (closer's spoken languages, refund policy, exact offer
  // inclusions, timezone coverage, etc.), R27 forces the AI to escalate
  // to "lemme check with the team" instead of inventing the answer.
  // verifiedDetails is free-form operator-maintained text listing facts
  // the AI CAN confidently claim. Everything outside this block is
  // escalation territory — l.galeza's "Anthony speaks German" fabrication
  // would have been blocked if verifiedDetails said nothing about
  // Anthony's languages.
  verifiedDetails          String?  @db.Text
  // Script-restructuring flags. Operators whose scripts ask capital
  // early (before the Typeform / booking handoff) can opt out of the
  // Layer-1 serializer inject (which would otherwise prepend a
  // duplicate verification question to "qualified" branches), and can
  // relax R3's sequence lock so Financial Screening can fire before
  // the soft pitch. Both default to false — existing accounts keep
  // the original prompt-enforced ordering. See the dual-enforcement
  // policy note at the top of ai-prompts.ts for rationale.
  skipR24ScriptInject         Boolean  @default(false)
  allowEarlyFinancialScreening Boolean  @default(false)
  // Multi-bubble delivery (single-message default preserves current
  // behaviour). When true, the system prompt injects a messages[]
  // schema so the LLM emits 1-4 short DM bubbles per turn, and the
  // delivery pipeline ships each one as a separate send with
  // realistic typing delays between.
  multiBubbleEnabled          Boolean  @default(false)
  responseDelayMin         Int      @default(300)     // Min response delay in seconds (default 5 min)
  responseDelayMax         Int      @default(600)     // Max response delay in seconds (default 10 min)
  voiceNotesEnabled        Boolean  @default(true)    // Whether voice notes are enabled
  setupStep                Int      @default(0)       // Onboarding progress (0-8), 8 = all steps complete
  setupComplete            Boolean  @default(false)   // All setup steps done
  isActive                 Boolean  @default(false)   // AI goes live only after activation
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  // Relations
  account               Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  trainingExamples      TrainingExample[]
  trainingUploads       TrainingUpload[]
  trainingConversations TrainingConversation[]
  breakdowns            PersonaBreakdown[]

  @@index([accountId, isActive])
}

enum BreakdownStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model PersonaBreakdown {
  id                       String          @id @default(cuid())
  accountId                String
  personaId                String
  sourceScriptHash         String
  sourceFileName           String?
  sourceText               String          @db.Text
  methodologySummary       String          @db.Text
  methodologySummaryEdited Boolean         @default(false)
  gaps                     Json?
  scriptSteps              Json?                     // Array of ScriptStep objects (sequential flow view)
  status                   BreakdownStatus @default(DRAFT)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  account        Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  persona        AIPersona            @relation(fields: [personaId], references: [id], onDelete: Cascade)
  sections       BreakdownSection[]
  ambiguities    BreakdownAmbiguity[]
  voiceNoteSlots VoiceNoteSlot[]
  scriptSlots    ScriptSlot[]

  @@index([accountId])
  @@index([personaId])
}

model BreakdownSection {
  id             String   @id @default(cuid())
  breakdownId    String
  sectionType    String
  title          String
  content        String   @db.Text
  sourceExcerpts Json
  confidence     String   @default("medium")
  userEdited     Boolean  @default(false)
  userApproved   Boolean  @default(false)
  orderIndex     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  breakdown PersonaBreakdown @relation(fields: [breakdownId], references: [id], onDelete: Cascade)

  @@index([breakdownId, orderIndex])
}

model BreakdownAmbiguity {
  id               String   @id @default(cuid())
  breakdownId      String
  question         String   @db.Text
  suggestedDefault String   @db.Text
  userAnswer       String?  @db.Text
  resolved         Boolean  @default(false)
  orderIndex       Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  breakdown PersonaBreakdown @relation(fields: [breakdownId], references: [id], onDelete: Cascade)

  @@index([breakdownId])
}

// ─── Voice Note Slot System ─────────────────────────────

enum VoiceNoteSlotStatus {
  EMPTY
  UPLOADED
  APPROVED
}

enum VoiceNoteFallback {
  BLOCK_UNTIL_FILLED
  SEND_TEXT_EQUIVALENT
  SKIP_ACTION
}

model VoiceNoteSlot {
  id                String              @id @default(cuid())
  accountId         String
  breakdownId       String?
  slotName          String
  description       String              @db.Text
  triggerCondition  Json                // { natural_language, structured: { step_id, branch_id, action_id } }
  audioFileUrl      String?
  audioDurationSecs Float?
  uploadedAt        DateTime?
  fallbackBehavior  VoiceNoteFallback   @default(SEND_TEXT_EQUIVALENT)
  fallbackText      String?             @db.Text
  status            VoiceNoteSlotStatus @default(EMPTY)
  userApproved      Boolean             @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  account   Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  breakdown PersonaBreakdown? @relation(fields: [breakdownId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([breakdownId])
  @@index([accountId, status])
}

// ─── Voice Note Library ─────────────────────────────────

enum VoiceNoteLibraryStatus {
  PROCESSING
  NEEDS_REVIEW
  ACTIVE
  DISABLED
  FAILED
}

model VoiceNoteLibraryItem {
  id                      String                   @id @default(cuid())
  accountId               String
  audioFileUrl            String
  durationSeconds         Float
  uploadedAt              DateTime                 @default(now())
  transcript              String?                  @db.Text
  summary                 String?                  @db.Text
  useCases                String[]                 @default([])
  leadTypes               String[]                 @default([])
  conversationStages      String[]                 @default([])
  emotionalTone           String?
  triggerConditionsNatural String?                  @db.Text
  triggers                Json?                    // Structured trigger objects array
  triggerDescription      String?                  @db.Text
  legacyTriggerText       String?                  @db.Text
  boundToScriptStep       String?
  scriptBindings          Json?                    // Array of { script_id, step_id, branch_id, action_id, bound_at }
  userLabel               String?
  userNotes               String?                  @db.Text
  priority                Int                      @default(0)
  active                  Boolean                  @default(false)
  embeddingVector         Json?
  autoSuggestedTriggers   Json?                    // LLM-generated trigger suggestions stored pre-approval
  suggestionStatus        TriggerSuggestionStatus? // null = no suggestions yet
  status                  VoiceNoteLibraryStatus   @default(PROCESSING)
  errorMessage            String?
  createdAt               DateTime                 @default(now())
  lastEditedAt            DateTime                 @updatedAt

  account            Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  scriptSlotBindings ScriptSlot[]
  scriptActions      ScriptAction[] @relation("ActionVoiceNote")

  @@index([accountId])
  @@index([accountId, status])
  @@index([accountId, active])
}

// ─── Script Slot System (Sprint 3) ─────────────────────

model ScriptSlot {
  id                String   @id @default(cuid())
  accountId         String
  breakdownId       String
  slotType          String                           // "voice_note" | "link" | "form" | "runtime_judgment" | "text_gap"
  stepId            String                           // which script step this slot belongs to
  branchId          String?                          // which branch within the step (null for step-level)
  actionId          String?                          // which action within the branch (null for step-level)
  detectedName      String?                          // e.g., "BREAKDOWN", "BOOKING LINK"
  description       String?  @db.Text                // AI-generated context description

  // Voice note specific
  suggestedTrigger  Json?                            // AI-suggested structured trigger from script context
  boundVoiceNoteId  String?                          // FK to VoiceNoteLibraryItem once bound

  // Link specific
  linkDescription   String?  @db.Text                // AI-generated description of what link should point to
  url               String?                          // user-provided URL

  // Form specific
  formSchema        Json?                            // { fields: [{ field_id, field_type, label, placeholder, required }] }
  formValues        Json?                            // user-provided values keyed by field_id

  // Text gap specific
  suggestedContent  String?  @db.Text                // AI-generated best-guess content
  userContent       String?  @db.Text                // user-provided content

  // Runtime judgment specific
  instruction       String?  @db.Text                // verbatim instruction from script
  context           String?  @db.Text                // AI-generated context for what factors to consider

  // Status
  status            String   @default("unfilled")    // "unfilled" | "filled" | "bound" | "partially_filled" | "complete"
  orderIndex        Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  account        Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  breakdown      PersonaBreakdown     @relation(fields: [breakdownId], references: [id], onDelete: Cascade)
  boundVoiceNote VoiceNoteLibraryItem? @relation(fields: [boundVoiceNoteId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([breakdownId])
  @@index([breakdownId, slotType])
}

model VoiceNoteSendLog {
  id           String   @id @default(cuid())
  accountId    String
  leadId       String
  voiceNoteId  String
  sentAt       DateTime @default(now())
  messageIndex Int
  triggerType  String // "stage_transition" | "content_intent" | "conversational_move"

  @@index([leadId, voiceNoteId, sentAt(sort: Desc)])
  @@index([accountId])
}

model TrainingExample {
  id            String           @id @default(cuid())
  accountId     String
  personaId     String
  category      TrainingCategory
  leadMessage   String           @db.Text  // What the lead said
  idealResponse String           @db.Text  // How the AI should reply
  notes         String?
  createdAt     DateTime         @default(now())

  // Relations
  account Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  persona AIPersona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@index([accountId, personaId])
  @@index([category])
}

// ─── Training Upload Pipeline Models ─────────────────────

model TrainingUpload {
  id                String       @id @default(cuid())
  accountId         String
  personaId         String
  fileName          String
  fileHash          String       // SHA-256 of PDF bytes for dedup
  blobUrl           String       // placeholder identifier
  pdfBase64         String?      @db.Text // original PDF as base64 for Claude native doc
  rawText           String?      @db.Text
  status            UploadStatus @default(PENDING)
  tokenEstimate     Int?
  conversationCount Int?
  errorMessage      String?      @db.Text
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  account       Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  persona       AIPersona             @relation(fields: [personaId], references: [id], onDelete: Cascade)
  conversations TrainingConversation[]

  @@unique([accountId, fileHash])
  @@index([accountId, status])
}

model TrainingConversation {
  id                 String          @id @default(cuid())
  uploadId           String
  accountId          String
  personaId          String
  leadIdentifier     String
  outcomeLabel       TrainingOutcome @default(UNKNOWN)
  contentHash        String          // SHA-256 of normalized message text
  messageCount       Int             @default(0)
  closerMessageCount Int             @default(0)
  leadMessageCount   Int             @default(0)
  voiceNoteCount     Int             @default(0)
  startedAt            DateTime?
  endedAt              DateTime?
  createdAt            DateTime        @default(now())

  // Analyzer-populated metadata (written back after LLM classification)
  leadType             String?         // beginner, intermediate, experienced_no_results, etc.
  primaryObjectionType String?         // price_objection, skepticism_or_scam_concern, etc.
  dominantStage        String?         // intro, qualification, objection_handling, etc.
  analyzedAt           DateTime?       // When metadata was last classified

  upload   TrainingUpload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  account  Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  persona  AIPersona        @relation(fields: [personaId], references: [id], onDelete: Cascade)
  messages TrainingMessage[]

  @@unique([accountId, contentHash])
  @@index([uploadId])
  @@index([accountId, personaId])
  @@index([accountId, leadType])
  @@index([accountId, dominantStage])
}

model TrainingMessage {
  id              String   @id @default(cuid())
  conversationId  String
  sender          String   // "CLOSER" | "LEAD"
  text            String?  @db.Text
  timestamp       DateTime?
  messageType     String   @default("TEXT") // TEXT, VOICE_NOTE, SYSTEM, REACTION, URL_DROP
  stage           String?  // intro, qualification, etc. (populated by analyzer)
  objectionType   String?  // price_objection, skepticism_or_scam_concern, etc. (populated by analyzer)
  orderIndex      Int
  embeddingVector Json?    // OpenAI text-embedding-3-small vector (lead messages only)

  conversation TrainingConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, orderIndex])
}

model IntegrationCredential {
  id          String              @id @default(cuid())
  accountId   String
  provider    IntegrationProvider
  credentials Json                // Encrypted: {accessToken, apiKey, etc.}
  metadata    Json?               // Non-secret config: {pageId, voiceId, calendarId}
  isActive    Boolean             @default(true)
  verifiedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, provider])
  @@index([accountId, provider])
}

// ─── Existing Models (now with accountId) ───────────────

model User {
  id              String   @id @default(cuid())
  accountId       String
  email           String   @unique
  name            String
  passwordHash    String
  role            Role     @default(SETTER)
  avatarUrl       String?
  isActive        Boolean  @default(true)
  commissionRate  Float?   @default(0)      // Percentage (e.g., 10.0 = 10%)
  totalCommission Float    @default(0)      // Lifetime earned commission
  avgResponseTime Int?                       // Average response time in seconds
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  account         Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  notifications   Notification[]
  sentMessages    Message[]       @relation("HumanSender")
  teamNotes       TeamNote[]
  leadsHandled    Int             @default(0)
  callsBooked     Int             @default(0)
  closeRate       Float?

  @@index([accountId])
  @@index([email])
  @@index([role])
}

model Lead {
  id                     String     @id @default(cuid())
  accountId              String
  name                   String
  handle                 String
  platform               Platform
  stage                  LeadStage  @default(NEW_LEAD)
  previousStage          LeadStage?
  stageEnteredAt         DateTime   @default(now())
  qualityScore           Int        @default(0)
  triggerType            TriggerType
  triggerSource          String?              // Which post/DM triggered entry
  bookedAt               DateTime?
  showedUp               Boolean    @default(false)
  closedAt               DateTime?
  revenue                Float?
  platformUserId         String?              // Meta user ID for API calls
  contentAttributionId   String?              // Which content generated this lead
  timezone               String?              // IANA timezone e.g. "America/New_York"
  experience             String?              // "beginner" | "intermediate" | "experienced"
  incomeLevel            String?              // "low" | "mid" | "high"
  geography              String?              // "US" | "Europe" | "Other"
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  // Relations
  account              Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  conversation         Conversation?
  notifications        Notification[]
  tags                 LeadTag[]
  teamNotes            TeamNote[]
  contentAttribution   ContentAttribution?  @relation(fields: [contentAttributionId], references: [id], onDelete: SetNull)
  crmOutcomes          CrmOutcome[]
  abTestAssignments    ABTestAssignment[]
  stageTransitions     LeadStageTransition[]
  scriptPositions      LeadScriptPosition[]
  inboundQualification InboundQualification?

  @@index([accountId, stage])
  @@index([accountId, platform])
  @@index([accountId, createdAt])
  @@index([contentAttributionId])
}

model Conversation {
  id              String              @id @default(cuid())
  leadId          String              @unique
  aiActive        Boolean             @default(true)
  unreadCount     Int                 @default(0)
  priorityScore   Int                 @default(0)       // 0-100, higher = hotter lead
  lastAIAnalysis  DateTime?                              // When AI last scored this conversation
  lastMessageAt   DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Self-Optimizing Layer: Outcome + Tracking
  outcome         ConversationOutcome @default(ONGOING)
  leadSource      LeadSource?
  leadIntentTag   LeadIntentTag       @default(NEUTRAL)
  dataSource      DataSource          @default(LIVE)
  consentToLog    Boolean             @default(true)

  // Stage reached timestamps (set once, when first reached)
  // Legacy stages (kept for historical data)
  stageQualificationAt         DateTime?
  stageVisionBuildingAt        DateTime?
  stagePainIdentificationAt    DateTime?
  stageSolutionOfferAt         DateTime?
  stageCapitalQualificationAt  DateTime?
  // Current stages (7-stage SOP sequence)
  stageOpeningAt               DateTime?
  stageSituationDiscoveryAt    DateTime?
  stageGoalEmotionalWhyAt      DateTime?
  stageUrgencyAt               DateTime?
  stageSoftPitchCommitmentAt   DateTime?
  stageFinancialScreeningAt    DateTime?
  stageBookingAt               DateTime?

  // Booking-stage state (populated as the lead answers each question)
  leadTimezone   String?   // IANA tz, e.g. "America/New_York" or "EST"
  leadEmail      String?   // Captured during Stage 7 booking info collection
  leadPhone      String?   // Optional if captured
  proposedSlots  Json?     // Last set of slots offered to lead: TimeSlot[]
  selectedSlot   Json?     // Slot lead confirmed: TimeSlot
  bookingId      String?   // LeadConnector appointment id after successful book
  bookingUrl     String?   // Fallback link if provider doesn't support server-side booking

  // Call-scheduling state (set by human operator via Call Details UI,
  // or by AI parsing from the lead's message with explicit confirmation).
  // Drives reminder scheduling + sidebar badges. Distinct from the booking
  // fields above: those track the automated Stage-7 flow; these track the
  // actual confirmed call the lead is showing up for.
  scheduledCallAt          DateTime?
  scheduledCallTimezone    String?
  scheduledCallSource      ScheduledCallSource?
  scheduledCallConfirmed   Boolean   @default(false)
  scheduledCallNote        String?
  scheduledCallUpdatedAt   DateTime?
  scheduledCallUpdatedBy   String?   // User.id — for audit trail

  // Relations
  lead           Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages       Message[]
  aiSuggestions  AISuggestion[]
  inboundQualification InboundQualification?
  scheduledMessages ScheduledMessage[]

  @@index([lastMessageAt])
  @@index([priorityScore])
  @@index([outcome])
  @@index([scheduledCallAt])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  sender         MessageSender
  content        String
  isVoiceNote    Boolean       @default(false)
  voiceNoteUrl   String?
  sentByUserId      String?                // Only for HUMAN sender
  platformMessageId String?                // Meta's message ID (event.message.mid) for dedup
  timestamp         DateTime   @default(now())

  // Self-Optimizing Layer: Effectiveness Tracking
  stage                      String?   // Conversation stage from AI response
  subStage                   String?   // Sub-stage (PATH_A, PATH_B, WATERFALL_L1-L4, etc.)
  stageConfidence            Float?    // 0-1 confidence in stage classification
  sentimentScore             Float?    // -1 to 1 lead sentiment (secondary signal)
  experiencePath             String?   // BEGINNER or EXPERIENCED (lead classification)
  objectionType              String?   // Detected objection: TRUST, MONEY, TIME, PRIOR_FAILURE, PARTNER
  stallType                  String?   // Detected stall: TIME_DELAY, MONEY_DELAY, THINKING, PARTNER, GHOST
  gotResponse                Boolean?  // Back-filled: did lead reply after this AI msg?
  leadContinuedConversation  Boolean?  // Back-filled: did lead send 2+ more msgs?
  responseTimeSeconds        Int?      // Back-filled: seconds until lead's next reply
  followUpAttemptNumber      Int?      // For ghosted lead follow-ups (1, 2, 3)
  systemPromptVersion        String?   // Semver of prompt used to generate this message

  // ── Closed-Loop Training Fields ────────────────────────────
  isHumanOverride            Boolean   @default(false) // True when human sent this instead of AI
  rejectedAISuggestionId     String?                   // FK to AISuggestion the human rejected
  editedFromSuggestion       Boolean   @default(false) // True if human text was similar to suggestion (>0.7)
  suggestionId               String?                   // FK to AISuggestion that generated this AI message
  humanOverrideNote          String?   @db.Text        // Optional 1-line reason from human
  loggedDuringTrainingPhase  Boolean   @default(false) // Snapshot: was account in ONBOARDING when saved?

  // ── Multi-Bubble Delivery ──────────────────────────────────
  // Nullable so legacy single-message rows remain unchanged. When
  // the AI generates 2-4 bubbles per turn, each bubble becomes its
  // own Message row linked via messageGroupId; bubbleIndex gives the
  // order within the group, bubbleTotalCount is denormalised for
  // easy queries. Rows with null messageGroupId are single-message
  // (implicit 1-bubble group).
  messageGroupId             String?
  bubbleIndex                Int?
  bubbleTotalCount           Int?
  intraGroupDelayMs          Int?

  // Relations
  conversation        Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentByUser          User?         @relation("HumanSender", fields: [sentByUserId], references: [id])
  suggestion          AISuggestion? @relation("SelectedSuggestion", fields: [suggestionId], references: [id])
  rejectedSuggestion  AISuggestion? @relation("RejectedSuggestion", fields: [rejectedAISuggestionId], references: [id])
  messageGroup        MessageGroup? @relation(fields: [messageGroupId], references: [id], onDelete: SetNull)

  @@unique([conversationId, platformMessageId])
  @@index([conversationId, timestamp])
  @@index([conversationId, sender, timestamp])
  @@index([messageGroupId])
}

// Multi-bubble message group. When the AI emits messages: string[]
// (via the multiBubbleEnabled persona flag), each string becomes a
// separate Message row all linked to one MessageGroup. The group
// tracks delivery lifecycle: bubbleCount, totalCharacters, when the
// last bubble completed, whether delivery failed mid-group, and any
// delivery notes (rate-limit events, human-aborted). completedAt and
// failedAt are mutually exclusive — one is set when the loop ends.
model MessageGroup {
  id              String    @id @default(cuid())
  conversationId  String
  generatedAt     DateTime  @default(now())
  aiSuggestionId  String?
  bubbleCount     Int
  totalCharacters Int
  sentByType      String    @default("AI") // 'AI' | 'HUMAN_BURST' (HUMAN_BURST deferred)
  completedAt     DateTime?
  failedAt        DateTime?
  deliveryNotes   Json?

  messages        Message[]
  aiSuggestion    AISuggestion? @relation(fields: [aiSuggestionId], references: [id], onDelete: SetNull)

  @@index([conversationId, generatedAt(sort: Desc)])
  @@index([aiSuggestionId])
}

model Notification {
  id        String           @id @default(cuid())
  accountId String
  userId    String?                     // null = team-wide
  type      NotificationType
  title     String
  body      String
  leadId    String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([accountId, userId, isRead])
  @@index([createdAt])
}

// ─── Phase 1: Competitive Feature Models ──────────────

model Tag {
  id        String    @id @default(cuid())
  name      String                            // e.g. "HIGH_INTENT", "GHOST_RISK"
  color     String    @default("#6B7280")     // Hex color for UI badge
  isAuto    Boolean   @default(false)         // true = AI-generated tag
  accountId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  account Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  leads   LeadTag[]

  @@unique([accountId, name])
  @@index([accountId])
}

model LeadTag {
  id         String   @id @default(cuid())
  leadId     String
  tagId      String
  appliedBy  String?                          // userId or "AI" for auto-tags
  confidence Float?                           // AI confidence score (0-1)
  createdAt  DateTime @default(now())

  // Relations
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([leadId, tagId])
  @@index([leadId])
  @@index([tagId])
}

model TeamNote {
  id        String   @id @default(cuid())
  content   String   @db.Text
  leadId    String
  authorId  String
  accountId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([accountId])
}

model ContentAttribution {
  id          String      @id @default(cuid())
  contentType ContentType                     // REEL, STORY, POST, LIVE, AD, etc.
  contentId   String?                         // Platform-specific content ID
  contentUrl  String?                         // URL to the original content
  caption     String?     @db.Text            // Caption text (or first portion)
  platform    Platform                        // INSTAGRAM, FACEBOOK
  accountId   String
  leadsCount  Int         @default(0)         // Denormalized count for performance
  revenue     Float       @default(0)         // Denormalized revenue total
  callsBooked Int         @default(0)         // Denormalized calls booked count
  postedAt    DateTime?                       // When the content was posted
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  leads   Lead[]

  @@unique([accountId, contentId, platform])
  @@index([accountId, createdAt])
  @@index([accountId, contentType])
}

// ─── Self-Optimizing Layer Models ─────────────────────

model PromptVersion {
  id              String   @id @default(cuid())
  accountId       String
  version         String   // Semver: "1.0.0", "1.1.0", etc.
  promptHash      String   // SHA-256 hash of rendered prompt (minus lead-specific vars)
  description     String?  // What changed from previous version
  changeType      String?  // "MAJOR" | "MINOR" | "PATCH"
  appliedBy       String?  // "ADMIN" | "STAGING_AUTO"
  optimizationId  String?  // Links to OptimizationSuggestion that triggered this
  promptContent   String?  @db.Text // Full prompt snapshot for rollback
  performanceBefore Json?  // {bookingRate, responseRate, avgTimeToBook}
  performanceAfter  Json?  // Populated after sufficient post-change data
  createdAt       DateTime @default(now())

  @@unique([accountId, version])
  @@index([accountId, createdAt])
}

model CrmOutcome {
  id         String   @id @default(cuid())
  accountId  String
  leadId     String
  showed     Boolean
  closed     Boolean  @default(false)
  dealValue  Float?
  closeReason String? // ENROLLED | NOT_READY | CANT_AFFORD | NO_SHOW | OTHER
  notes      String?  @db.Text
  source     String   @default("manual") // "webhook" | "manual"
  receivedAt DateTime @default(now())

  // Relations
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([accountId, leadId])
  @@index([accountId, receivedAt])
}

// ─── A/B Testing + Optimization Models ──────────────

enum ABTestStatus {
  RUNNING
  COMPLETED
  PAUSED
}

enum OptimizationStatus {
  PENDING_APPROVAL
  APPROVED
  STAGING_TEST
  APPLIED
  REJECTED
  MODIFIED
  REVERTED
}

enum OptimizationType {
  SYSTEM_PROMPT_UPDATE
  MESSAGE_VARIATION
  FLOW_ADJUSTMENT
}

model ABTest {
  id               String       @id @default(cuid())
  accountId        String
  testName         String
  stage            String       // Conversation stage this test applies to
  variantA         String       @db.Text
  variantB         String       @db.Text
  metric           String       @default("response_rate") // Primary metric to optimize
  sampleSizeTarget Int          @default(50) // Per variant
  countA           Int          @default(0)
  countB           Int          @default(0)
  resultsA         Json?        // {responseRate, bookingRate, avgMessagesToBook}
  resultsB         Json?        // {responseRate, bookingRate, avgMessagesToBook}
  winner           String?      // "A" | "B" | "INCONCLUSIVE"
  status           ABTestStatus @default(RUNNING)
  createdAt        DateTime     @default(now())
  completedAt      DateTime?

  // Relations
  assignments ABTestAssignment[]

  @@index([accountId, status])
}

model ABTestAssignment {
  id         String   @id @default(cuid())
  testId     String
  leadId     String
  variant    String   // "A" | "B"
  assignedAt DateTime @default(now())

  // Relations
  test ABTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  lead Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([testId, leadId])
  @@index([testId, variant])
}

model OptimizationSuggestion {
  id                 String             @id @default(cuid())
  accountId          String
  type               OptimizationType
  reasoning          String             @db.Text
  currentVersion     String?            // Current prompt version
  proposedVersion    String?            // Proposed new version
  proposedChanges    String?            @db.Text // Description of what to change
  supportingData     Json?              // {sampleSize, confidence, expectedImprovement, segmentBreakdown}
  stagingTestResults Json?              // {conversationsTested, regressionsDetected, comparisonSummary}
  status             OptimizationStatus @default(PENDING_APPROVAL)
  adminNotes         String?            @db.Text
  createdAt          DateTime           @default(now())
  resolvedAt         DateTime?

  @@index([accountId, status])
  @@index([accountId, createdAt])
}

// ─── Booking Prediction Models ──────────────────────

model PredictionModel {
  id              String   @id @default(cuid())
  accountId       String
  version         Int      @default(1)
  modelType       String   @default("logistic_regression") // logistic_regression | gradient_boosted
  weights         Json     // Model coefficients/weights
  features        Json     // Feature names and config used
  trainingSize    Int      // Number of conversations used to train
  holdoutSize     Int      // Number of conversations in holdout set
  accuracy        Float    // Accuracy on holdout set (0-1)
  auc             Float    // AUC-ROC on holdout set (0-1)
  precision       Float    @default(0)
  recall          Float    @default(0)
  isActive        Boolean  @default(true)
  trainedAt       DateTime @default(now())

  // Relations
  predictions PredictionLog[]

  @@unique([accountId, version])
  @@index([accountId, isActive])
}

model PredictionLog {
  id               String   @id @default(cuid())
  accountId        String
  conversationId   String
  modelId          String
  predictedProb    Float    // 0-1 booking probability
  actualOutcome    String?  // BOOKED | LEFT_ON_READ | etc (filled later)
  features         Json     // Feature values used for this prediction
  predictedAt      DateTime @default(now())

  // Relations
  model PredictionModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([accountId, conversationId])
  @@index([modelId, predictedAt])
}

// ─── Delay Queue ────────────────────────────────────────

enum ScheduledReplyStatus {
  PENDING
  PROCESSING
  SENT
  CANCELLED
  FAILED
}

model ScheduledReply {
  id              String               @id @default(cuid())
  conversationId  String
  accountId       String
  scheduledFor    DateTime             // Absolute time when reply should be sent
  status          ScheduledReplyStatus @default(PENDING)
  attempts        Int                  @default(0)
  lastError       String?              @db.Text
  messageType     String?              // 'text' | 'voice_note' | null (null = legacy pre-generation)
  generatedResult Json?                // Pre-generated AI result (for VN-aware path)
  createdAt       DateTime             @default(now())
  processedAt     DateTime?

  @@index([status, scheduledFor])
  @@index([conversationId, status])
}

// ---------------------------------------------------------------------------
// Scheduled outbound messages — call reminders + keepalives + re-engagement
// ---------------------------------------------------------------------------
// Distinct from ScheduledReply (which handles the debounced reply-to-lead
// queue). ScheduledMessage fires SYSTEM-initiated outbound touches that are
// tied to a calendar event or conversation state, not a direct lead reply.

enum ScheduledMessageType {
  DAY_BEFORE_REMINDER
  MORNING_OF_REMINDER
  WINDOW_KEEPALIVE
  RE_ENGAGEMENT
  CUSTOM
}

enum ScheduledMessageStatus {
  PENDING
  FIRING    // optimistic lock between cron pickup and send
  FIRED
  CANCELLED
  FAILED
}

enum ScheduledMessageCreatedBy {
  SYSTEM
  HUMAN
  AI
}

enum ScheduledCallSource {
  HUMAN_ENTRY
  AI_PARSED_FROM_LEAD
  CALENDAR_INTEGRATION
}

model ScheduledMessage {
  id                 String                    @id @default(cuid())
  conversationId     String
  accountId          String
  scheduledFor       DateTime
  messageType        ScheduledMessageType
  messageBody        String?                   @db.Text
  generateAtSendTime Boolean                   @default(true)
  status             ScheduledMessageStatus    @default(PENDING)
  firedAt            DateTime?
  /// Denormalized so we can cancel reminders tied to a specific call
  /// without extra joins when the call gets rescheduled.
  relatedCallAt      DateTime?
  createdBy          ScheduledMessageCreatedBy @default(SYSTEM)
  createdByUserId    String?
  attempts           Int                       @default(0)
  lastError          String?                   @db.Text
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([conversationId, status])
  @@index([conversationId, messageType, status])
}

// ---------------------------------------------------------------------------
// Voice Note Timing Settings (independent from AI Persona text delay)
// ---------------------------------------------------------------------------

model VoiceNoteTimingSettings {
  id        String   @id @default(cuid())
  accountId String   @unique
  minDelay  Float    @default(10)   // Minimum delay in seconds before sending
  maxDelay  Float    @default(60)   // Maximum delay in seconds before sending
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Lead Stage Transition History
// ---------------------------------------------------------------------------

model LeadStageTransition {
  id             String    @id @default(cuid())
  leadId         String
  fromStage      LeadStage
  toStage        LeadStage
  transitionedBy String    // "ai" | "user" | "system"
  reason         String?
  createdAt      DateTime  @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

// ─── Script Template System (Sprint 3 Revised) ──────────

enum ScriptActionType {
  send_message
  ask_question
  send_voice_note
  send_link
  send_video
  form_reference
  runtime_judgment
  wait_for_response
  wait_duration
}

enum LeadScriptStatus {
  active
  completed
  stalled
}

enum ScriptCreatedVia {
  template
  blank
  upload_parsed
}

enum ParserConfidence {
  high
  medium
  low
}

enum ParserActionStatus {
  filled
  needs_review
  needs_user_input
}

enum VoiceNoteBindingMode {
  specific
  runtime_match
}

enum TriggerSuggestionStatus {
  pending
  approved
  edited
  rejected
}

// R24 audit trail. Every time the AI generates a reply that would
// route a lead into the booking-handoff branch, we write one row
// here so R24 compliance is queryable as a single SQL, not a full
// diagnostic. verificationAskedAtMessageId + confirmedAtMessageId
// are null when no verification Q&A was found in the conversation;
// routingAllowed tells you whether the gate permitted the send.
// regenerationForced fires when the gate blocked the first attempt
// and pushed the LLM to retry with an override directive.
model BookingRoutingAudit {
  id                               String   @id @default(cuid())
  conversationId                   String
  accountId                        String
  personaMinimumCapital            Int?
  verificationAskedAtMessageId     String?
  verificationConfirmedAtMessageId String?
  routingAllowed                   Boolean
  regenerationForced               Boolean  @default(false)
  createdAt                        DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([accountId, createdAt])
  @@index([routingAllowed, createdAt])
}

model Script {
  id          String   @id @default(cuid())
  accountId   String
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(false)
  isDefault          Boolean          @default(false)
  createdVia         ScriptCreatedVia @default(blank)
  originalUploadText String?          @db.Text
  lastParsedAt       DateTime?
  parseWarnings      Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  account       Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  steps         ScriptStep[]
  forms         ScriptForm[]
  leadPositions LeadScriptPosition[]

  @@index([accountId])
  @@index([accountId, isActive])
}

model ScriptStep {
  id          String   @id @default(cuid())
  scriptId    String
  stepNumber  Int
  title       String
  description String?  @db.Text
  objective        String?           @db.Text
  parserConfidence ParserConfidence?
  userConfirmed    Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  script        Script               @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  branches      ScriptBranch[]
  actions       ScriptAction[]
  leadPositions LeadScriptPosition[]

  @@index([scriptId, stepNumber])
}

model ScriptBranch {
  id                   String   @id @default(cuid())
  stepId               String
  branchLabel          String
  conditionDescription String?  @db.Text
  sortOrder            Int               @default(0)
  parserConfidence     ParserConfidence?
  userConfirmed        Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  step          ScriptStep           @relation(fields: [stepId], references: [id], onDelete: Cascade)
  actions       ScriptAction[]
  leadPositions LeadScriptPosition[]

  @@index([stepId, sortOrder])
}

model ScriptAction {
  id           String           @id @default(cuid())
  stepId       String
  branchId     String?
  actionType   ScriptActionType
  content      String?          @db.Text
  voiceNoteId  String?
  bindingMode  VoiceNoteBindingMode   @default(runtime_match)
  linkUrl      String?
  linkLabel    String?
  formId       String?
  waitDuration Int?
  sortOrder        Int                @default(0)
  parserConfidence ParserConfidence?
  parserStatus     ParserActionStatus?
  userConfirmed    Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  step      ScriptStep            @relation(fields: [stepId], references: [id], onDelete: Cascade)
  branch    ScriptBranch?         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  voiceNote VoiceNoteLibraryItem? @relation("ActionVoiceNote", fields: [voiceNoteId], references: [id], onDelete: SetNull)
  form      ScriptForm?           @relation(fields: [formId], references: [id], onDelete: SetNull)

  @@index([stepId, sortOrder])
  @@index([branchId, sortOrder])
}

model ScriptForm {
  id          String   @id @default(cuid())
  scriptId    String
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  script  Script            @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  fields  ScriptFormField[]
  actions ScriptAction[]

  @@index([scriptId])
}

model ScriptFormField {
  id         String   @id @default(cuid())
  formId     String
  fieldLabel String
  fieldValue String?  @db.Text
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  form ScriptForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, sortOrder])
}

model LeadScriptPosition {
  id              String           @id @default(cuid())
  leadId          String
  scriptId        String
  currentStepId   String
  currentBranchId String?
  status          LeadScriptStatus @default(active)
  updatedAt       DateTime         @updatedAt

  lead   Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  script Script        @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  step   ScriptStep    @relation(fields: [currentStepId], references: [id], onDelete: Cascade)
  branch ScriptBranch? @relation(fields: [currentBranchId], references: [id], onDelete: SetNull)

  @@unique([leadId, scriptId])
  @@index([leadId])
  @@index([scriptId])
}

// ─── Training Data Adequacy Analyzer (Sprint 4) ─────────────────────

model TrainingDataAnalysis {
  id                      String   @id @default(cuid())
  accountId               String
  runAt                   DateTime @default(now())
  overallScore            Int                      // 0-100 weighted readiness
  categoryScores          Json                     // { quantity, voice_style, lead_type, stage, outcome, objection }
  totalConversations      Int
  totalMessages           Int
  recommendations         Json                     // [{ category, severity, description, recommendation, evidence }]
  estimatedCostCents      Int?
  status                  String   @default("complete") // running | complete | failed
  errorMessage            String?  @db.Text
  analyzedConversationIds Json?                    // string[] — IDs of conversations included in this analysis
  categoryMetrics         Json?                    // Per-category distributions for incremental merge
  account                 Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, runAt(sort: Desc)])
}

// ─── Voice Quality Gate Failures (logging) ────────────────────────

model VoiceQualityFailure {
  id          String   @id @default(cuid())
  accountId   String
  message     String   @db.Text     // The AI message that failed
  score       Float                 // 0.0–1.0 quality score
  hardFails   Json                  // string[] of hard fail reasons
  attempt     Int                   // Which attempt (1, 2, 3)
  leadMessage String?  @db.Text     // The lead message that triggered this
  createdAt   DateTime @default(now())

  @@index([accountId, createdAt(sort: Desc)])
}

// ─── Closed-Loop Training: AI Suggestion Logging ─────────────────────

model AISuggestion {
  id                          String   @id @default(cuid())
  conversationId              String
  accountId                   String
  generatedAt                 DateTime @default(now())

  // Generated response
  responseText                String   @db.Text
  retrievalTier               Int?                      // Which few-shot tier produced examples (1, 2, 3)
  qualityGateAttempts         Int      @default(1)      // How many LLM calls before quality passed
  qualityGateScore            Float?                    // Final voice quality gate score (0.0–1.0)
  qualityGatePassedFirstAttempt Boolean @default(false) // True if first attempt passed

  // Context snapshot at generation time
  intentClassification        String?                   // Content intent detected (e.g. "price_objection")
  intentConfidence            Float?                    // Intent classifier confidence (0.0–1.0)
  leadStageSnapshot           String?                   // Lead stage at generation (e.g. "QUALIFYING")
  leadTypeSnapshot            String?                   // Mapped lead type (e.g. "beginner")

  // Outcome tracking
  wasSelected                 Boolean  @default(false)  // True if AI auto-sent this response
  wasRejected                 Boolean  @default(false)  // True if human overrode with a different message
  wasEdited                   Boolean  @default(false)  // True if human text was similar (>0.7 similarity)
  finalSentText               String?  @db.Text         // What was actually sent (AI or human text)
  similarityToFinalSent       Float?                    // Cosine sim between responseText and finalSentText

  // Training phase context
  generatedDuringTrainingPhase Boolean @default(false)  // Snapshot: was account in ONBOARDING?

  // Multi-bubble delivery. When the LLM emitted messages[] the full
  // array lives here (ordered). bubbleCount mirrors length. Override
  // detection prefers messageBubbles.join('\n') over responseText
  // when available. Legacy suggestions have messageBubbles=null and
  // bubbleCount=1.
  messageBubbles              Json?
  bubbleCount                 Int      @default(1)

  // Relations
  conversation                Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  account                     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  selectedByMessages          Message[]    @relation("SelectedSuggestion")
  rejectedByMessages          Message[]    @relation("RejectedSuggestion")
  messageGroups               MessageGroup[]

  @@index([conversationId, generatedAt(sort: Desc)])
  @@index([accountId, generatedAt(sort: Desc)])
  @@index([accountId, generatedDuringTrainingPhase, generatedAt(sort: Desc)])
  @@index([wasSelected, generatedAt(sort: Desc)])
  @@index([wasRejected, generatedAt(sort: Desc)])
}

// ─── Inbound Qualification: stage-skip intelligence ─────────────────
// One row per conversation, written on the first AI generation cycle.
// Records the classifier's read of the lead's opening messages: which
// stage to start at, what was extracted (experience / pain / goal /
// financial / intent), and whether the skip-cap had to clamp the
// suggestion. Used by the prompt to inject pre-qualified context so the
// AI doesn't re-ask questions the lead already answered.

model InboundQualification {
  id                     String   @id @default(cuid())
  conversationId         String   @unique
  accountId              String
  leadId                 String   @unique
  classifiedAt           DateTime @default(now())

  // Classifier outputs
  suggestedStartStage    Int                 // 1-7, raw classifier suggestion
  finalStartStage        Int                 // after skip-cap applied
  stagesSkipped          Int                 // finalStartStage - 1
  stageSkipReason        String   @db.Text
  classifierConfidence   Float    @default(0)
  capped                 Boolean  @default(false)

  // Extracted data
  hasExperience          Boolean  @default(false)
  experienceLevel        String?             // beginner | intermediate | experienced
  hasPainPoint           Boolean  @default(false)
  painPointSummary       String?  @db.Text
  hasGoal                Boolean  @default(false)
  goalSummary            String?  @db.Text
  hasUrgency             Boolean  @default(false)
  urgencySummary         String?  @db.Text
  hasFinancialInfo       Boolean  @default(false)
  financialSummary       String?  @db.Text
  hasExplicitIntent      Boolean  @default(false)
  intentType             String?             // learn_strategy | join_mentorship | ...
  isInbound              Boolean  @default(false)

  // Raw model response for debugging
  rawResponse            Json?

  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([accountId, classifiedAt(sort: Desc)])
  @@index([accountId, finalStartStage])
}
